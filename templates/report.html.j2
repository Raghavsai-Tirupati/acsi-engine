<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>acsi — Certification Report</title>
    <style>
      {% if font_display %}@font-face { font-family: "Rajdhani"; font-style: normal; font-weight: 500; font-display: swap; src: url({{ font_display }}) format("woff2"); }{% endif %}
      {% if font_heading %}@font-face { font-family: "Plus Jakarta Sans"; font-style: normal; font-weight: 400 700; font-display: swap; src: url({{ font_heading }}) format("woff2"); }{% endif %}
      :root {
        --ink: #18181b; --ink-2: #52525b; --ink-3: #71717a; --faint: #8a8f98;
        --bg: #ffffff; --card: #ffffff; --sunken: #f6f6f8;
        --line: #e7e7ea; --line-strong: #d4d4d8;
        --accent: #5b5bd6; --accent-soft: #ececfb; --accent-line: #dedefa;
        --pass: #15803d; --pass-soft: #e7f7ec; --pass-line: #bfe6cb;
        --block: #c0362c; --block-soft: #fbeae7; --block-line: #f0cabf;
        --font-display: "Rajdhani", system-ui, sans-serif;
        --font-heading: "Plus Jakarta Sans", -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
        --font-body: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --ink: #e9ebef; --ink-2: #9ba2ad; --ink-3: #868d97; --faint: #6b7280;
          --bg: #0e0e11; --card: #16171b; --sunken: #1a1b20;
          --line: #26272d; --line-strong: #34363d;
          --accent: #9a9af2; --accent-soft: #1e1e33; --accent-line: #33335a;
          --pass: #4ade80; --pass-soft: #10231a; --pass-line: #1f4d34;
          --block: #f2867d; --block-soft: #251413; --block-line: #4d211c;
        }
      }
      * { box-sizing: border-box; border-radius: 0 !important; }
      html { -webkit-text-size-adjust: 100%; }
      body {
        color: var(--ink); background: var(--bg); margin: 0;
        font-family: var(--font-body); line-height: 1.55; font-size: 16px;
        -webkit-font-smoothing: antialiased;
      }
      main { max-width: 860px; margin: 0 auto; padding: 32px 24px 72px; }
      h1, h2, h3 { line-height: 1.22; margin: 0; font-family: var(--font-heading); font-weight: 640; letter-spacing: -0.01em; }
      p { margin: 0; }
      a { color: inherit; }
      code, .mono { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size: 0.86em; }
      .muted { color: var(--ink-2); }
      .faint { color: var(--faint); }
      .small { font-size: 0.86rem; }
      .eyebrow { font-family: var(--font-display); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.14em; color: var(--ink-3); font-weight: 600; }

      .brand { display: flex; align-items: baseline; gap: 14px; padding-bottom: 20px; border-bottom: 2px solid var(--ink); flex-wrap: wrap; }
      .wordmark { font-family: var(--font-display); font-weight: 500; font-size: 30px; letter-spacing: 0.08em; text-transform: lowercase; color: var(--ink); line-height: 1; }
      .brand-meta { margin-left: auto; text-align: right; }
      .brand-title { font-family: var(--font-display); text-transform: uppercase; letter-spacing: 0.16em; font-size: 0.82rem; color: var(--ink-2); font-weight: 600; }
      .brand-sub { font-size: 0.82rem; color: var(--faint); margin-top: 2px; }

      .section { margin-top: 40px; }
      .section > .eyebrow { display: block; margin-bottom: 8px; }
      .lead { font-size: 1.0rem; margin: 0 0 18px; max-width: 64ch; color: var(--ink); }
      .lead.muted { color: var(--ink-2); }

      .fake-banner { background: var(--block); color: #fff; font-family: var(--font-display); font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; text-align: center; padding: 15px; margin: 22px 0 0; font-size: 1.05rem; }

      .hero { border: 1px solid var(--line-strong); padding: 26px; margin-top: 24px; background: var(--card); }
      .verdict { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
      .verdict .badge { font-family: var(--font-heading); font-size: 2.3rem; font-weight: 800; letter-spacing: -0.02em; line-height: 1; padding: 8px 18px; }
      .verdict.pass .badge { color: var(--pass); background: var(--pass-soft); border: 1px solid var(--pass-line); }
      .verdict.block .badge { color: var(--block); background: var(--block-soft); border: 1px solid var(--block-line); }
      .verdict .tag { font-family: var(--font-display); font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-2); }
      .coverage { font-size: 1.05rem; margin: 20px 0 0; max-width: 64ch; }
      .coverage-plain { color: var(--ink-2); margin-top: 8px; max-width: 64ch; }
      .headline { font-size: 1.16rem; font-weight: 560; margin-top: 18px; max-width: 64ch; letter-spacing: -0.01em; }
      .headline.unresolved { color: var(--ink-2); font-weight: 500; font-size: 1.04rem; }
      .hero .note { margin-top: 14px; }

      .howto { border-left: 3px solid var(--accent); background: var(--accent-soft); padding: 16px 18px; margin-top: 22px; }
      .howto .eyebrow { color: var(--accent); margin-bottom: 8px; display: block; }
      .howto p { color: var(--ink); font-size: 0.94rem; max-width: 66ch; }
      .howto p + p { margin-top: 7px; }
      @media (prefers-color-scheme: dark) { .howto p { color: var(--ink); } }

      .cards { display: grid; gap: 12px; }
      @media (min-width: 660px) { .cards.criteria { grid-template-columns: 1fr 1fr 1fr; } }
      .card { border: 1px solid var(--line-strong); padding: 16px; background: var(--card); }
      .card .status { display: inline-block; font-family: var(--font-display); font-size: 0.74rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding: 2px 9px; }
      .card.pass .status { color: var(--pass); background: var(--pass-soft); border: 1px solid var(--pass-line); }
      .card.block .status { color: var(--block); background: var(--block-soft); border: 1px solid var(--block-line); }
      .card.na .status { color: var(--ink-2); background: var(--sunken); border: 1px solid var(--line); }
      .card h3 { font-size: 0.98rem; margin: 10px 0 5px; }
      .card .means { color: var(--ink-2); font-size: 0.88rem; }
      .card .io { margin-top: 11px; font-size: 0.88rem; border-top: 1px solid var(--line); padding-top: 10px; }
      .card .io .k { font-family: var(--font-display); text-transform: uppercase; font-size: 0.68rem; letter-spacing: 0.06em; color: var(--faint); }

      .cluster { border: 1px solid var(--line-strong); padding: 2px 16px; background: var(--card); margin-bottom: 10px; }
      .cluster > summary { list-style: none; cursor: pointer; padding: 13px 0; display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; }
      .cluster > summary::-webkit-details-marker { display: none; }
      .cluster > summary::before { content: "+"; color: var(--faint); font-family: var(--font-display); font-weight: 600; }
      .cluster[open] > summary::before { content: "–"; }
      .cluster .cname { font-weight: 600; font-family: var(--font-heading); }
      .cluster .pill { font-family: var(--font-display); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.06em; padding: 2px 8px; border: 1px solid var(--line-strong); color: var(--ink-2); }
      .cluster .pill.crit { color: var(--block); border-color: var(--block-line); background: var(--block-soft); }
      .cluster .count { color: var(--ink-2); font-variant-numeric: tabular-nums; margin-left: auto; font-size: 0.9rem; }
      .exemplar { border-top: 1px solid var(--line); padding: 14px 0; }
      .exemplar .lbl { font-family: var(--font-display); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--faint); margin-bottom: 4px; }
      .exemplar .lbl + pre, .exemplar .lbl + .val { margin-top: 0; margin-bottom: 12px; }
      pre { background: var(--sunken); border: 1px solid var(--line); padding: 12px; overflow-x: auto; white-space: pre-wrap; word-break: break-word; font-size: 0.83rem; margin: 0; }
      .val { font-size: 0.9rem; }

      table { border-collapse: collapse; width: 100%; font-size: 0.94rem; }
      td, th { text-align: left; padding: 10px 0; border-bottom: 1px solid var(--line); vertical-align: top; }
      th { font-weight: 500; color: var(--ink); width: 50%; padding-right: 16px; }
      th .def { display: block; font-weight: 400; color: var(--faint); font-size: 0.78rem; margin-top: 2px; line-height: 1.4; }
      td { font-variant-numeric: tabular-nums; color: var(--ink); }
      tr:last-child td, tr:last-child th { border-bottom: 0; }

      details.expander > summary { cursor: pointer; color: var(--ink-2); font-family: var(--font-display); text-transform: uppercase; letter-spacing: 0.08em; font-size: 0.78rem; padding: 6px 0; }
      details.expander[open] > summary { color: var(--ink); }
      .footer { margin-top: 52px; padding-top: 18px; border-top: 2px solid var(--ink); color: var(--ink-2); font-size: 0.88rem; }
      .footer .mono { word-break: break-all; }
      .footer .wordmark { font-size: 18px; color: var(--ink-2); }

      .review { border: 1px solid var(--line-strong); padding: 18px; margin-top: 24px; background: var(--sunken); }
      .review label { display: block; margin: 8px 0; font-size: 0.9rem; }
      .review input, .review select, .review textarea { width: 100%; border: 1px solid var(--line-strong); padding: 7px; font: inherit; background: var(--card); color: var(--ink); }
      .review button { border: 1px solid var(--ink); background: var(--ink); color: var(--bg); cursor: pointer; font: inherit; padding: 7px 14px; margin-top: 8px; font-family: var(--font-display); text-transform: uppercase; letter-spacing: 0.06em; font-size: 0.8rem; }

      @media (max-width: 460px) {
        main { padding: 24px 16px 56px; }
        .verdict .badge { font-size: 1.9rem; }
        th, td { display: block; width: auto; }
        th { border-bottom: 0; padding-bottom: 0; }
        td { padding-top: 2px; }
        tr { display: block; padding: 8px 0; border-bottom: 1px solid var(--line); }
        tr:last-child { border-bottom: 0; }
      }
      @media print {
        :root { --bg: #fff; --card: #fff; --ink: #111; --ink-2: #444; }
        body { color: #111; background: #fff; }
        .section, .card, .cluster, .hero, .howto { break-inside: avoid; }
        details.expander, .review { display: none; }
        a[href]::after { content: ""; }
      }
    </style>
    <script>{{ alpine_js|safe }}</script>
  </head>
  <body>
    <main>
      <header class="brand">
        <span class="wordmark">acsi</span>
        <div class="brand-meta">
          <div class="brand-title">Certification Report</div>
          <div class="brand-sub">{{ payload.manifest.workload }} · issued {{ cert.header.issued_at }}</div>
        </div>
      </header>

      {% if payload.client_mode == "fake" %}
      <section class="fake-banner" role="alert">FAKE CLIENTS — NOT A CERTIFICATION</section>
      {% endif %}

      {# (a) verdict + headlines #}
      <section class="hero">
        <div class="verdict {{ 'pass' if view.is_pass else 'block' }}">
          <span class="badge">{{ payload.verdict }}</span>
          <span class="tag">candidate {{ payload.manifest.candidate.model }} vs. baseline {{ payload.manifest.baseline.model }}</span>
        </div>
        <p class="coverage">{{ payload.coverage_sentence }}</p>
        {% if view.coverage_plain %}
        <p class="coverage-plain">{{ view.coverage_plain }}</p>
        {% endif %}
        <p class="headline">{{ view.regressed_headline }}</p>
        {% if view.unresolved_headline %}
        <p class="headline unresolved">{{ view.unresolved_headline }}</p>
        {% endif %}
        {% if payload.coverage.zero_event_bound_sentence %}
        <p class="note muted small">{{ payload.coverage.zero_event_bound_sentence }}</p>
        {% endif %}
        {% if payload.coverage.human_override_footnote %}
        <p class="note muted small">{{ payload.coverage.human_override_footnote }}</p>
        {% endif %}
      </section>

      {# How to read this certificate #}
      <section class="howto">
        <span class="eyebrow">How to read this certificate</span>
        <p>A <strong>pair</strong> is one real input answered twice — once by the current model (baseline), once by the candidate you are considering.</p>
        <p>A pair <strong>regressed</strong> when the candidate's answer broke a required rule (an assertion) or a panel of independent judges graded it worse than the baseline's.</p>
        <p>A pair is <strong>unresolved</strong> when the judges could not reach enough valid, agreeing votes to decide it; these are counted against the candidate so the verdict stays on the safe side.</p>
        <p><strong>BLOCK</strong> means do not switch to the candidate until the named failures below are fixed. <strong>PASS</strong> means the candidate is safe to switch to for the inputs tested here.</p>
      </section>

      {% if review_mode %}
      <section class="review" x-data="reviewPanel()" x-init="load()">
        <span class="eyebrow">Review queue</span>
        <p class="small muted" x-text="status"></p>
        <h3 class="small">Unresolved queue</h3>
        <template x-for="item in unresolved" :key="item.pair_id">
          <div class="card">
            <strong class="mono small" x-text="item.pair_id"></strong>
            <p class="small">Current outcome: <span x-text="item.outcome"></span></p>
            <label>Override
              <select x-model="item.to_outcome">
                <option value="equivalent">equivalent</option>
                <option value="candidate_better">candidate_better</option>
                <option value="worse_minor">worse_minor</option>
                <option value="worse_critical">worse_critical</option>
                <option value="unresolved">unresolved</option>
              </select>
            </label>
            <label>Note <input x-model="item.note"></label>
            <button type="button" x-on:click="override(item)">Save override</button>
          </div>
        </template>
        <p class="small" x-show="unresolved.length === 0">No unresolved judge outcomes.</p>
        <h3 class="small" style="margin-top:14px">Promote assertion</h3>
        <label>ID <input x-model="draft.id"></label>
        <label>Type
          <select x-model="draft.type">
            <option value="contains">contains</option>
            <option value="not_contains">not_contains</option>
            <option value="regex">regex</option>
          </select>
        </label>
        <label>Severity
          <select x-model="draft.severity">
            <option value="critical">critical</option>
            <option value="major">major</option>
            <option value="minor">minor</option>
          </select>
        </label>
        <label>Params JSON <textarea rows="3" x-model="draft.params"></textarea></label>
        <button type="button" x-on:click="promote()">Promote assertion</button>
      </section>
      <script>
        function reviewPanel() {
          return {
            draft: {id: "", type: "contains", severity: "major", params: "{}"},
            status: "Loading review data",
            unresolved: [],
            async load() {
              const response = await fetch("/api/run");
              const payload = await response.json();
              this.unresolved = payload.unresolved_queue.map((item) => ({
                ...item, note: "", to_outcome: "equivalent",
              }));
              this.status = `${payload.overrides.length} override rows recorded`;
            },
            async override(item) {
              const response = await fetch("/api/override", {
                method: "POST", headers: {"content-type": "application/json"},
                body: JSON.stringify({note: item.note, pair_id: item.pair_id, to_outcome: item.to_outcome}),
              });
              this.status = await response.text();
              await this.load();
            },
            async promote() {
              const params = JSON.parse(this.draft.params || "{}");
              const response = await fetch("/api/promote-assertion", {
                method: "POST", headers: {"content-type": "application/json"},
                body: JSON.stringify({...this.draft, params}),
              });
              this.status = await response.text();
            },
          };
        }
      </script>
      {% endif %}

      {# (b) three criteria as pass/fail cards #}
      <section class="section">
        <span class="eyebrow">Pass criteria</span>
        <p class="lead muted">All three must pass to certify. This run is a {{ payload.verdict }}.</p>
        <div class="cards criteria">
          {% for c in view.criteria %}
          <div class="card {{ 'pass' if c.is_pass else ('block' if c.is_block else 'na') }}">
            <span class="status">{{ c.status }}</span>
            <h3>{{ c.label }}</h3>
            <p class="means">{{ c.meaning }}</p>
            <div class="io"><span class="k">Observed</span><br>{{ c.input }}<br><span class="k" style="margin-top:6px;display:inline-block">Allowed</span><br>{{ c.threshold }}</div>
          </div>
          {% endfor %}
        </div>
      </section>

      {# (c) failure clusters — the evidence layer #}
      <section class="section">
        <span class="eyebrow">Failure clusters</span>
        <p class="lead muted">Regressions grouped by mechanism. Expand any cluster for the exact input, the candidate's failing response, and why it failed.</p>
        {% if view.unresolved_reconciliation %}
        <p class="small muted" style="margin-bottom:12px">{{ view.unresolved_reconciliation }}</p>
        {% endif %}
        {% for cluster in payload.clusters %}
        {% set rows = cluster_evidence.get(cluster.cluster_id) %}
        <details class="cluster">
          <summary>
            <span class="cname">{{ cluster.name }}</span>
            <span class="pill {{ 'crit' if cluster.severity == 'worse_critical' else '' }}">{{ cluster.severity|severity_label }}</span>
            <span class="count">{{ cluster.count }} pair{{ '' if cluster.count == 1 else 's' }} · {{ cluster.share_of_sampled|pct }}</span>
          </summary>
          {% if rows %}
          {% for row in rows %}
          <div class="exemplar">
            <div class="lbl">Input prompt</div>
            <pre>{{ row.prompt }}</pre>
            <div class="lbl">Candidate response</div>
            <pre>{{ row.response }}</pre>
            {% if row.reason %}
            <div class="lbl">Why it failed</div>
            <p class="val mono">{{ row.reason }}</p>
            {% else %}
            <div class="lbl">Panel outcome</div>
            <p class="val">{{ cluster.name }}</p>
            {% endif %}
          </div>
          {% endfor %}
          {% else %}
          {% if cluster.reasons %}
          <div class="exemplar"><div class="lbl">Why it failed</div>
            {% for reason in cluster.reasons %}<p class="val mono">{{ reason }}</p>{% endfor %}
          </div>
          {% endif %}
          {% for exemplar in cluster.exemplars %}
          <div class="exemplar"><div class="lbl">Input prompt</div><pre>{{ exemplar }}</pre></div>
          {% endfor %}
          {% endif %}
          {% if cluster.patch_diff %}
          <div class="exemplar"><div class="lbl">Proposed patch</div><pre>{{ cluster.patch_diff }}</pre></div>
          {% endif %}
        </details>
        {% else %}
        <p class="muted">No regression clusters were recorded.</p>
        {% endfor %}
      </section>

      {# (d) noise floor & stats #}
      <section class="section">
        <span class="eyebrow">Noise floor</span>
        <p class="lead">{{ view.noise_narrative }}</p>
        <table>
          <tr><th>Candidate disagreement rate<span class="def">share of inputs where the candidate's answer differed enough to count</span></th><td>{{ view.noise.candidate_rate }}</td></tr>
          <tr><th>Candidate 95% confidence interval<span class="def">statistical range that rate could fall in</span></th><td>{{ view.noise.candidate_ci }}</td></tr>
          <tr><th>Baseline self-disagreement<span class="def">how much the current model already varies when given the very same input twice — the noise bar</span></th><td>{{ view.noise.noise_rate }}</td></tr>
          <tr><th>How the noise bar was set<span class="def">calibrated from repeated baseline runs, or a fixed default</span></th><td>{{ view.noise.bar_source }}</td></tr>
        </table>
      </section>

      {# (e) judge panel #}
      <section class="section">
        <span class="eyebrow">Judge panel</span>
        <p class="lead">{{ view.judge_narrative }}</p>
        <table>
          <tr><th>Judges</th><td>{{ payload.judge_panel.models|join(", ") }}</td></tr>
          <tr><th>Pairs judged</th><td>{{ payload.judge_panel.completed_pairs }}</td></tr>
          <tr><th>Valid-verdict rate<span class="def">share of judge calls that returned a usable verdict; the rest abstained</span></th><td>{% if payload.judge_health.valid_verdict_rate is not none %}{{ payload.judge_health.valid_verdict_rate|pct }} ({{ payload.judge_health.valid_verdicts }}/{{ payload.judge_health.evaluations }}){% else %}n/a{% endif %}</td></tr>
          <tr><th>Inter-judge agreement<span class="def">how often the judges gave the same verdict on a pair</span></th><td>{% if payload.judge_panel.agreement_percent is not none %}{{ payload.judge_panel.agreement_percent|pct_value }}{% else %}n/a — {{ payload.judge_panel.agreement_reason }}{% endif %}</td></tr>
        </table>
        {% if payload.judge_health.context %}
        <p class="small muted" style="margin-top:12px">{{ payload.judge_health.context }}</p>
        {% endif %}
      </section>

      {# (f) cost & latency #}
      <section class="section">
        <span class="eyebrow">Cost &amp; latency</span>
        <p class="lead muted">Per-response differences between the candidate and the baseline. Positive deltas mean the candidate is slower, longer, or costlier.</p>
        <table>
          <tr><th>Baseline mean latency</th><td>{{ payload.cost_latency.baseline_mean_latency_ms|ms }}</td></tr>
          <tr><th>Candidate mean latency</th><td>{{ payload.cost_latency.candidate_mean_latency_ms|ms }}</td></tr>
          <tr><th>Latency delta<span class="def">candidate minus baseline response time</span></th><td>{{ payload.cost_latency.latency_delta_ms|ms }}</td></tr>
          <tr><th>Baseline mean output tokens</th><td>{{ payload.cost_latency.baseline_mean_output_tokens|decimal(1) }}</td></tr>
          <tr><th>Candidate mean output tokens</th><td>{{ payload.cost_latency.candidate_mean_output_tokens|decimal(1) }}</td></tr>
          <tr><th>Output length inflation<span class="def">candidate output length ÷ baseline output length</span></th><td>{{ payload.cost_latency.output_length_inflation|multiplier }}</td></tr>
          <tr><th>USD delta<span class="def">candidate minus baseline cost per response</span></th><td>{{ payload.cost_latency.usd_delta|usd }}</td></tr>
        </table>
      </section>

      {# (g) scope & dedup disclosure #}
      <section class="section">
        <span class="eyebrow">Scope &amp; exclusions</span>
        <p class="lead muted">What this certificate covers, and what was collapsed before sampling. It certifies only the sampled inputs, not future traffic.</p>
        <table>
          <tr><th>Workload</th><td>{{ payload.scope.workload }}</td></tr>
          <tr><th>Real inputs collected</th><td>{{ payload.coverage.n_collected }}</td></tr>
          <tr><th>After near-duplicate merge<span class="def">near-duplicate inputs were merged so one pattern can't dominate</span></th><td>{{ payload.coverage.n_after_dedup }}</td></tr>
          <tr><th>Duplicates collapsed</th><td>{{ payload.coverage.dedup_collapsed }} (jaccard ≥ {{ payload.coverage.dedup_method.jaccard_threshold }}, shingle {{ payload.coverage.dedup_method.shingle_size }})</td></tr>
          <tr><th>Inputs tested</th><td>{{ payload.coverage.n }}</td></tr>
          <tr><th>Sampling method</th><td>{{ payload.coverage.sampling_method }}</td></tr>
          <tr><th>Excluded</th><td>{{ payload.coverage.exclusion_percent|pct_value }}</td></tr>
          <tr><th>Personal data scrubbed</th><td>{{ payload.scope.scrubbed }}</td></tr>
        </table>
      </section>

      {# raw values for auditors — the only place exact technical keys appear in text #}
      <section class="section">
        <details class="expander rawview">
          <summary>Raw technical values (for auditors)</summary>
          <table>
            <tr><th>criteria</th><td class="mono">{% for c in payload.criteria %}{{ c.id }}={{ c.passed }}{{ "; " if not loop.last }}{% endfor %}</td></tr>
            <tr><th>candidate_regression_rate</th><td class="mono">{{ payload.candidate_regression_rate|default(0)|decimal(6) }}</td></tr>
            <tr><th>noise_floor_raw.tau (similarity threshold)</th><td class="mono">{{ payload.noise_floor_raw.tau|default(0.9)|decimal(4) }}</td></tr>
            <tr><th>noise_floor_raw.threshold_source</th><td class="mono">{{ payload.noise_floor_raw.threshold_source|default("unknown") }}</td></tr>
            <tr><th>judge_panel.krippendorff_alpha</th><td class="mono">{% if payload.judge_panel.krippendorff_alpha is not none %}{{ payload.judge_panel.krippendorff_alpha|decimal(4) }}{% else %}n/a ({{ payload.judge_panel.krippendorff_alpha_reason }}){% endif %}</td></tr>
            <tr><th>judge_health.parse_failure_rate</th><td class="mono">{% if payload.judge_health.parse_failure_rate is not none %}{{ payload.judge_health.parse_failure_rate|decimal(6) }} ({{ payload.judge_health.parse_failures }}){% else %}n/a{% endif %}</td></tr>
            <tr><th>judge_health.position_inconsistency_rate</th><td class="mono">{% if payload.judge_health.position_inconsistency_rate is not none %}{{ payload.judge_health.position_inconsistency_rate|decimal(6) }} ({{ payload.judge_health.position_inconsistencies }}){% else %}n/a{% endif %}</td></tr>
            <tr><th>judge_panel.calibration_accuracy</th><td class="mono">{% if payload.judge_panel.calibration_accuracy is not none %}{{ payload.judge_panel.calibration_accuracy|decimal(6) }}{% else %}n/a ({{ payload.judge_panel.calibration_accuracy_reason }}){% endif %}</td></tr>
            <tr><th>mode</th><td class="mono">{{ payload.mode }}</td></tr>
            <tr><th>client_mode</th><td class="mono">{{ payload.client_mode }}</td></tr>
            <tr><th>engine_version</th><td class="mono">{{ payload.engine_version }}</td></tr>
            <tr><th>config_hash</th><td class="mono">{{ payload.config_hash.value if payload.config_hash is mapping else payload.config_hash }}</td></tr>
            <tr><th>run_id</th><td class="mono">{{ payload.run_id }}</td></tr>
            {% for cluster in payload.clusters %}
            <tr><th>cluster {{ cluster.cluster_id }}</th><td class="mono">severity={{ cluster.severity }}, share={{ cluster.share_of_sampled|decimal(6) }}</td></tr>
            {% endfor %}
          </table>
          <p class="small muted" style="margin-top:10px">Full signed payload is embedded below as JSON for machine verification.</p>
        </details>
      </section>

      {# (h) signature footer #}
      <div class="footer">
        <p><span class="wordmark">acsi</span> · Verified: {{ cert.header.algo }} — verify offline with <code>acsi verify cert.json</code>.
        Engine {{ payload.engine_version }} · run {{ payload.run_id }} · issued {{ cert.header.issued_at }}.</p>
        <details class="expander">
          <summary>Signature &amp; public key</summary>
          <p class="small faint" style="margin-top:8px">Public key</p>
          <p class="mono small">{{ cert.header.public_key }}</p>
          <p class="small faint" style="margin-top:8px">Signature</p>
          <p class="mono small">{{ cert.signature }}</p>
        </details>
      </div>

      <script type="application/json" id="acsi-certificate">{{ certificate_json }}</script>
    </main>
  </body>
</html>
