<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>ACSI Certificate Report</title>
    <style>
      body { color: #111827; font-family: ui-sans-serif, system-ui, sans-serif; margin: 0; }
      main { margin: 0 auto; max-width: 1080px; padding: 32px 20px; }
      h1, h2, h3 { line-height: 1.2; margin: 0 0 12px; }
      h2 { border-top: 1px solid #d1d5db; margin-top: 28px; padding-top: 24px; }
      table { border-collapse: collapse; width: 100%; }
      th, td { border-bottom: 1px solid #e5e7eb; padding: 8px; text-align: left; vertical-align: top; }
      th { background: #f9fafb; font-weight: 700; }
      pre { background: #f3f4f6; overflow: auto; padding: 12px; white-space: pre-wrap; }
      .banner { border: 2px solid #111827; padding: 18px; }
      .verdict { font-size: 2rem; font-weight: 800; }
      .muted { color: #4b5563; }
      .grid { display: grid; gap: 16px; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); }
      .panel { border: 1px solid #d1d5db; padding: 12px; }
      .small { font-size: 0.9rem; }
      .stack { display: grid; gap: 10px; }
      input, select, textarea { border: 1px solid #9ca3af; font: inherit; padding: 6px; }
      button { border: 1px solid #111827; background: #fff; cursor: pointer; font: inherit; padding: 6px 10px; }
    </style>
    <script>{{ alpine_js|safe }}</script>
  </head>
  <body>
    <main>
      <section class="banner">
        <div class="verdict">{{ payload.verdict }}</div>
        <p>{{ payload.coverage_sentence }}</p>
        <p>
          {{ payload.regressed_pairs.count }}/{{ payload.coverage.n }} sampled pairs regressed
          ({{ payload.regressed_pairs.rate|pct }}) — {{ payload.regressed_pairs.by_source.assertion }}
          by assertion, {{ payload.regressed_pairs.by_source.judge }} by judge,
          {{ payload.regressed_pairs.by_source.both }} by both.
        </p>
        {% if payload.coverage.zero_event_bound_sentence %}
        <p>{{ payload.coverage.zero_event_bound_sentence }}</p>
        {% endif %}
        {% if payload.coverage.human_override_footnote %}
        <p class="small">{{ payload.coverage.human_override_footnote }}</p>
        {% endif %}
      </section>

      {% if review_mode %}
      <section class="panel" x-data="reviewPanel()" x-init="load()">
        <h2>Review Queue</h2>
        <p class="small muted" x-text="status"></p>
        <h3>Unresolved Queue</h3>
        <template x-for="item in unresolved" :key="item.pair_id">
          <div class="panel">
            <strong x-text="item.pair_id"></strong>
            <p class="small">Current outcome: <span x-text="item.outcome"></span></p>
            <label>Override
              <select x-model="item.to_outcome">
                <option value="equivalent">equivalent</option>
                <option value="candidate_better">candidate_better</option>
                <option value="worse_minor">worse_minor</option>
                <option value="worse_critical">worse_critical</option>
                <option value="unresolved">unresolved</option>
              </select>
            </label>
            <label>Note <input x-model="item.note"></label>
            <button type="button" x-on:click="override(item)">Save Override</button>
          </div>
        </template>
        <p x-show="unresolved.length === 0">No unresolved judge outcomes.</p>

        <h3>Promote Assertion</h3>
        <div class="stack">
          <label>ID <input x-model="draft.id"></label>
          <label>Type
            <select x-model="draft.type">
              <option value="contains">contains</option>
              <option value="not_contains">not_contains</option>
              <option value="regex">regex</option>
            </select>
          </label>
          <label>Severity
            <select x-model="draft.severity">
              <option value="critical">critical</option>
              <option value="major">major</option>
              <option value="minor">minor</option>
            </select>
          </label>
          <label>Params JSON <textarea rows="3" x-model="draft.params"></textarea></label>
          <button type="button" x-on:click="promote()">Promote Assertion</button>
        </div>
      </section>
      <script>
        function reviewPanel() {
          return {
            draft: {id: "", type: "contains", severity: "major", params: "{}"},
            status: "Loading review data",
            unresolved: [],
            async load() {
              const response = await fetch("/api/run");
              const payload = await response.json();
              this.unresolved = payload.unresolved_queue.map((item) => ({
                ...item,
                note: "",
                to_outcome: "equivalent",
              }));
              this.status = `${payload.overrides.length} override rows recorded`;
            },
            async override(item) {
              const response = await fetch("/api/override", {
                method: "POST",
                headers: {"content-type": "application/json"},
                body: JSON.stringify({
                  note: item.note,
                  pair_id: item.pair_id,
                  to_outcome: item.to_outcome,
                }),
              });
              this.status = await response.text();
              await this.load();
            },
            async promote() {
              const params = JSON.parse(this.draft.params || "{}");
              const response = await fetch("/api/promote-assertion", {
                method: "POST",
                headers: {"content-type": "application/json"},
                body: JSON.stringify({...this.draft, params}),
              });
              this.status = await response.text();
            },
          };
        }
      </script>
      {% endif %}

      <h2>Criteria</h2>
      <table>
        <thead><tr><th>Criterion</th><th>Input</th><th>Threshold</th><th>Status</th></tr></thead>
        <tbody>
          {% for criterion in payload.criteria %}
          <tr>
            <td>{{ criterion|criterion_label }}</td>
            <td>{{ criterion|criterion_input }}</td>
            <td>{{ criterion|criterion_threshold }}</td>
            <td>{{ criterion|criterion_status }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>

      <h2>Noise Floor And Candidate</h2>
      <table>
        <tbody>
          <tr><th>Candidate rate</th><td>{{ payload.candidate_disagreement.rate|pct }}</td></tr>
          <tr><th>Candidate CI</th><td>{{ payload.candidate_disagreement.lower|ci_pct }} to {{ payload.candidate_disagreement.upper|ci_pct }}</td></tr>
          <tr><th>Noise floor</th><td>{% if payload.noise_floor %}{{ payload.noise_floor.rate|pct }}{% else %}Unavailable{% endif %}</td></tr>
          <tr><th>Threshold τ</th><td>{{ payload.noise_floor_raw.tau|default(0.9)|decimal(2) }}</td></tr>
          <tr><th>threshold_source</th><td>{{ payload.noise_floor_raw.threshold_source|default("unknown") }}</td></tr>
          <tr><th>Mode</th><td>{{ payload.mode }}</td></tr>
        </tbody>
      </table>

      <h2>Assertions</h2>
      <div class="grid">
        {% for severity, summary in payload.assertions_by_severity.items() %}
        <div class="panel">
          <h3>{{ severity }}</h3>
          <p>Configured: {{ summary.configured|length }}</p>
          <p>Failures: {{ summary.failures }}</p>
        </div>
        {% endfor %}
      </div>

      <h2>Judge Panel</h2>
      <table>
        <tbody>
          <tr><th>Models</th><td>{{ payload.judge_panel.models|join(", ") }}</td></tr>
          <tr><th>Families</th><td>{{ payload.judge_panel.families|join(", ") }}</td></tr>
          <tr><th>Order swap</th><td>{{ payload.judge_panel.order_swap }}</td></tr>
          <tr><th>Agreement</th><td>{% if payload.judge_panel.agreement_percent is not none %}{{ payload.judge_panel.agreement_percent|pct_value }}{% else %}n/a — {{ payload.judge_panel.agreement_reason }}{% endif %}</td></tr>
          <tr><th>Alpha</th><td>{% if payload.judge_panel.krippendorff_alpha is not none %}{{ payload.judge_panel.krippendorff_alpha|decimal(2) }}{% else %}n/a — {{ payload.judge_panel.krippendorff_alpha_reason }}{% endif %}</td></tr>
          <tr><th>Calibration</th><td>{% if payload.judge_panel.calibration_accuracy is not none %}{{ payload.judge_panel.calibration_accuracy|pct }}{% else %}n/a — {{ payload.judge_panel.calibration_accuracy_reason }}{% endif %}</td></tr>
        </tbody>
      </table>

      <h2>Clusters And Patches</h2>
      {% for cluster in payload.clusters %}
      <section class="panel" x-data="{open:false}">
        <h3>{{ cluster.name }} <span class="small muted">({{ cluster.count }})</span></h3>
        <p>{{ cluster.description }}</p>
        <p class="small">Severity: {{ cluster.severity }}; share: {{ cluster.share_of_sampled|pct }}</p>
        <button type="button" x-on:click="open=!open">Details</button>
        <div x-show="open">
          {% for exemplar in cluster.exemplars %}
          <pre>{{ exemplar }}</pre>
          {% endfor %}
          {% if cluster.patch_diff %}
          <pre>{{ cluster.patch_diff }}</pre>
          {% endif %}
        </div>
      </section>
      {% else %}
      <p>No regression clusters were recorded.</p>
      {% endfor %}

      <h2>Cost, Latency, And Tokens</h2>
      <table>
        <tbody>
          <tr><th>Baseline mean latency</th><td>{{ payload.cost_latency.baseline_mean_latency_ms|ms }}</td></tr>
          <tr><th>Candidate mean latency</th><td>{{ payload.cost_latency.candidate_mean_latency_ms|ms }}</td></tr>
          <tr><th>Latency delta</th><td>{{ payload.cost_latency.latency_delta_ms|ms }}</td></tr>
          <tr><th>Baseline mean output tokens</th><td>{{ payload.cost_latency.baseline_mean_output_tokens|decimal(1) }}</td></tr>
          <tr><th>Candidate mean output tokens</th><td>{{ payload.cost_latency.candidate_mean_output_tokens|decimal(1) }}</td></tr>
          <tr><th>Tokenizer inflation</th><td>{{ payload.cost_latency.tokenizer_inflation|multiplier }}</td></tr>
          <tr><th>USD delta</th><td>{{ payload.cost_latency.usd_delta|usd }}</td></tr>
        </tbody>
      </table>

      <h2>Scope And Exclusions</h2>
      <table>
        <tbody>
          <tr><th>Workload</th><td>{{ payload.scope.workload }}</td></tr>
          <tr><th>Sample size</th><td>{{ payload.coverage.n }}</td></tr>
          <tr><th>Sampling method</th><td>{{ payload.coverage.sampling_method }}</td></tr>
          <tr><th>Exclusion percent</th><td>{{ payload.coverage.exclusion_percent|pct_value }}</td></tr>
          <tr><th>Scrubbed</th><td>{{ payload.scope.scrubbed }}</td></tr>
        </tbody>
      </table>

      <h2>Signature</h2>
      <p class="small">Verify offline with <code>acsi verify cert.json</code>.</p>
      <table>
        <tbody>
          <tr><th>Algorithm</th><td>{{ cert.header.algo }}</td></tr>
          <tr><th>Public key</th><td>{{ cert.header.public_key }}</td></tr>
          <tr><th>Signature</th><td>{{ cert.signature }}</td></tr>
        </tbody>
      </table>

      <script type="application/json" id="acsi-certificate">{{ certificate_json }}</script>
    </main>
  </body>
</html>
